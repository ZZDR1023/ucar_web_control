[Unit]
Description=UCAR base and lidar sensors
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ucar
WorkingDirectory=/home/ucar
Environment=ROS_MASTER_URI=http://10.90.122.179:11311
Environment=ROS_IP=10.90.122.179
ExecStart=/bin/bash -lc 'source /opt/ros/melodic/setup.bash && source /home/ucar/ucar_ws/devel/setup.bash && exec /home/ucar/start_sensors.sh'
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
